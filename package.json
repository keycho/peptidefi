{
  "name": "peptide-oracle",
  "version": "0.0.0",
  "private": true,
  "description": "BioHash — on-chain commit layer for peptide market observations and TWAPs (biohash.network).",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "db:link": "supabase link --project-ref mnquozxfniasbpaavcos --workdir packages/db",
    "db:push": "supabase db push --workdir packages/db",
    "db:diff": "supabase db diff --workdir packages/db",
    "db:gen-types": "supabase gen types typescript --project-id mnquozxfniasbpaavcos --schema public > packages/db/types.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "init-peg-mainnet": "tsx scripts/initialize-peg-mainnet.ts"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/spl-token": "^0.4.8",
    "@solana/web3.js": "^1.95.4",
    "@types/chai": "^4.3.5",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.16.11",
    "chai": "^4.3.10",
    "mocha": "^10.2.0",
    "prettier": "^3.3.3",
    "supabase": "^1.226.4",
    "ts-mocha": "^10.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["supabase"]
  }
}
