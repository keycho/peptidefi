{
  "address": "2cKMtgXPQt1zT8aWzBAh9LkH3Cf11ris6NDBjrq9J8s7",
  "metadata": {
    "name": "biohash_peg",
    "version": "0.1.0",
    "spec": "0.1.0",
    "description": "BioHash peg program — V0.1. Oracle-side IDL containing only the surface needed by peg-pusher.ts (update_peg_state instruction + PegState account)."
  },
  "instructions": [
    {
      "name": "update_peg_state",
      "discriminator": [198, 92, 207, 70, 175, 255, 200, 13],
      "accounts": [
        {
          "name": "update_authority",
          "signer": true,
          "relations": ["peg_state"]
        },
        {
          "name": "peg_state",
          "writable": true,
          "pda": {
            "seeds": [
              { "kind": "const", "value": [112, 101, 103, 95, 115, 116, 97, 116, 101] },
              { "kind": "account", "path": "peg_state.peptide_code", "account": "PegState" }
            ]
          }
        },
        { "name": "clock", "address": "SysvarC1ock11111111111111111111111111111111" }
      ],
      "args": [
        { "name": "new_twap", "type": "u64" },
        { "name": "observation_set_root", "type": { "array": ["u8", 32] } }
      ]
    }
  ],
  "accounts": [
    { "name": "PegState", "discriminator": [100, 166, 10, 181, 119, 220, 240, 156] }
  ],
  "events": [
    { "name": "TwapUpdateEvent", "discriminator": [247, 39, 70, 122, 180, 24, 141, 32] }
  ],
  "errors": [
    { "code": 6000, "name": "NoTwapSet", "msg": "No TWAP has been pushed yet." },
    { "code": 6001, "name": "TwapStale", "msg": "TWAP is older than max_twap_age_slots." },
    { "code": 6002, "name": "TwapStepTooLarge", "msg": "TWAP step exceeds max_twap_step_bps." },
    { "code": 6003, "name": "UnauthorizedUpdater", "msg": "Caller did not match peg_state.update_authority." },
    { "code": 6004, "name": "ZeroAmount", "msg": "Amount must be greater than zero." },
    { "code": 6007, "name": "ArithmeticOverflow", "msg": "Arithmetic overflow." }
  ],
  "types": [
    {
      "name": "PegState",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "peptide_code", "type": { "array": ["u8", 16] } },
          { "name": "peptide_token_mint", "type": "pubkey" },
          { "name": "update_authority", "type": "pubkey" },
          { "name": "current_twap", "type": "u64" },
          { "name": "current_twap_slot", "type": "u64" },
          { "name": "current_twap_updated_at", "type": "i64" },
          { "name": "current_twap_observation_set_root", "type": { "array": ["u8", 32] } },
          { "name": "max_twap_age_slots", "type": "u64" },
          { "name": "max_twap_step_bps", "type": "u16" },
          { "name": "mint_fee_bps", "type": "u16" },
          { "name": "burn_fee_bps", "type": "u16" },
          { "name": "total_minted", "type": "u128" },
          { "name": "total_burned", "type": "u128" },
          { "name": "mint_count", "type": "u64" },
          { "name": "burn_count", "type": "u64" },
          { "name": "update_count", "type": "u64" },
          { "name": "bump", "type": "u8" },
          { "name": "_reserved", "type": { "array": ["u8", 64] } }
        ]
      }
    },
    {
      "name": "TwapUpdateEvent",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "peptide_code", "type": { "array": ["u8", 16] } },
          { "name": "previous_twap", "type": "u64" },
          { "name": "new_twap", "type": "u64" },
          { "name": "observation_set_root", "type": { "array": ["u8", 32] } },
          { "name": "slot", "type": "u64" }
        ]
      }
    }
  ]
}
