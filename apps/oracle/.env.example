# Copy to .env and fill in. .env is gitignored.
#
# All variables marked REQUIRED must be present at startup; the service
# refuses to come up otherwise (apps/oracle/src/config.ts validates).
#
# See docs/specs/01-onchain-commit-layer/03-service-architecture.md
# (§3.5 keypair, §3.6 RPC, §3.9 health) for the rationale behind each.

# ─── REQUIRED ───────────────────────────────────────────────────────────────

# Solana hot wallet that signs every commit. Base58-encoded 64-byte secret
# key. The matching pubkey must be published per §05.2.4 (GitHub +
# socials + docs site cross-reference).
#
# DO NOT commit. Mark as a Railway secret. See docs/operator-setup.md §3
# for generation procedure.
#
# Devnet vs mainnet: use a SEPARATE keypair for devnet shakedown deploys.
# The production-published authority pubkey (docs/oracle-authority.md)
# must NEVER sign devnet txs — devnet signatures are auditable on the
# devnet cluster and could be confused for "real" oracle attestations.
ORACLE_SOLANA_PRIVATE_KEY=

# Solana RPC URL. The cluster is implied by the URL — devnet vs mainnet
# is a deploy-time choice, not a runtime flag.
#
#   mainnet:  https://mainnet.helius-rpc.com/?api-key=<KEY>
#   devnet:   https://devnet.helius-rpc.com/?api-key=<KEY>
#
# Same Helius account works for both clusters. Devnet has no real
# economic exposure but DOES anchor on a separate, browseable
# transaction history; treat devnet keys as semi-confidential.
ORACLE_RPC_URL=

# OPTIONAL. Stamped on every commit_cycles / twap_commits row this oracle
# writes (DB column added in migration 0033). Lets the API and frontend
# distinguish devnet history from mainnet commits after the cutover.
#
# If absent, derived from ORACLE_RPC_URL: any URL containing "devnet" →
# 'devnet', "testnet" → 'testnet', anything else → 'mainnet-beta'.
# Set this explicitly when your RPC URL doesn't carry a recognisable
# cluster substring (e.g. a custom RPC behind a Cloudflare Worker).
#
# Allowed values: devnet | mainnet-beta | testnet
# SOLANA_CLUSTER=mainnet-beta

# ─── Peg pusher (off by default; opt-in per-deploy) ────────────────────────
#
# When PEG_PUSHER_ENABLED=false (or unset), the oracle behaves exactly
# as before — TWAP commits land on-chain, no peg state is touched. The
# peg pusher exists so the on-chain peg's current_twap stays fresh
# enough for mint/burn instructions to not revert with TwapStale once
# the peg program is deployed (devnet today, mainnet later).
#
# Master switch. "true" or "1" enables; anything else (including
# unset) disables.
# PEG_PUSHER_ENABLED=true

# Required when enabled. Address of the deployed peg program on the
# same cluster as ORACLE_RPC_URL.
# PEG_PROGRAM_ID=DAgK6HKtGRt8LFwxhypuEJ225JEhtjiCG3TrcdJmtW4r

# Comma-separated peptide codes the pusher is allowed to push for.
# A peptide listed here must have its peg_state PDA initialised on
# chain (initialize_peg_state) before push attempts succeed; until
# then the pusher logs "peg PDA missing" once and skips.
# Empty list = pusher on but pushing nothing (useful while staging).
# PEG_PEPTIDES=BPC157

# Compute-budget priority fee for peg push txs, in microlamports/CU.
# Default 1000 = 0.001 lamports/CU. Bumped 2× per retry up to a
# 1_000_000 ceiling.
# PEG_PUSH_PRIORITY_FEE_LAMPORTS=1000

# Maximum retry attempts on retryable errors (network / blockhash /
# preflight). Non-retryable program errors (TwapStepTooLarge,
# UnauthorizedUpdater, ZeroAmount) skip retry. Default 3.
# PEG_PUSH_MAX_RETRIES=3

# Supabase project this service writes commit_cycles / twap_commits /
# commit_observations into. Same project as the rest of the stack.
#
# As of the peptide-oracle pivot the canonical project is
# mnquozxfniasbpaavcos.supabase.co. The earlier biohack.market project
# (pjsjaspntdjecfitogtc) is preserved read-only.
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Direct Postgres connection URL for the oracle service.
#
# Why this is separate from SUPABASE_URL: the oracle needs persistent
# connections (advisory lock per §3.8.1 must hold for the lifetime of
# the process). PostgREST / supabase-js is request-scoped and would
# release the lock between calls. So the oracle uses the `postgres`
# npm package against the direct Postgres endpoint while the rest of
# the stack continues to use supabase-js.
#
# Use the SESSION-mode connection string (port 5432), NOT the pooler
# transaction-mode endpoint (port 6543) — pooled-transaction-mode
# connections release advisory locks between statements. Both the
# direct (db.<ref>.supabase.co:5432) and the pooler-session
# (aws-1-<region>.pooler.supabase.com:5432) endpoints work; the
# pooler one is recommended on Railway for connection-recycling
# friendliness.
#
# Format:  postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres
ORACLE_DATABASE_URL=

# ─── OPTIONAL (with sensible defaults) ──────────────────────────────────────

# Health endpoint port. Railway assigns the public port; this is the
# internal listen port that Railway's healthcheck hits.
HEALTH_PORT=8080

# Fallback RPC URL for §3.6.2 manual failover. Leave blank for v1
# (single-RPC operation).
ORACLE_RPC_URL_FALLBACK=

# ─── Balance thresholds (per §07.2.2 v1=26-peptide tuning) ──────────────────
# At median priority fees, ~0.23 SOL covers a 30-day buffer. At the high
# cap (~0.69 SOL/30d) the defaults below give ~13 days warn / ~7 days
# critical of headroom.
ORACLE_BALANCE_WARN_SOL=0.30
ORACLE_BALANCE_CRITICAL_SOL=0.15

# Refuse to start if balance is below this at boot. Catches misconfigured
# deploys before they generate a wave of insufficient-SOL failures.
ORACLE_MIN_STARTUP_BALANCE_SOL=0.05

# How often to refresh the cached balance for /health. Default 5 min.
ORACLE_BALANCE_CHECK_INTERVAL_MS=300000

# ─── Polling cadences (per §03.2.1, §03.3.1) ────────────────────────────────
# Cycle poller cadence: how often we check scraper_runs for new completed
# cycles needing a commit. Default 30s.
ORACLE_CYCLE_POLL_INTERVAL_MS=30000

# TWAP poller cadence: how often the TWAP-loop wakes to check the
# top-of-hour boundary. Default 60s.
ORACLE_TWAP_POLL_INTERVAL_MS=60000

# ─── Confirmation polling (per §03.4.6) ─────────────────────────────────────
# Total time to wait for a submitted tx to reach finalized commitment.
# Default 90s — covers worst-case finalization under congestion.
ORACLE_CONFIRMATION_TIMEOUT_MS=90000

# How often to poll getSignatureStatuses while waiting for finality.
ORACLE_CONFIRMATION_POLL_INTERVAL_MS=3000

# ─── Health staleness rule (per §03.9.2) ────────────────────────────────────
# If cycle.last_commit_at is older than this, /health flips to 503.
ORACLE_HEALTH_STALE_THRESHOLD_MS=1800000

# Warm-up window after startup during which staleness checks are skipped
# (so a fresh deploy isn't immediately reported unhealthy).
ORACLE_HEALTH_WARMUP_MS=3600000

# ─── Retry budget (per §03.7) ───────────────────────────────────────────────
# Hard cap on total retry_count across in-flight + long-tail retries.
# After this many attempts a row stays at status='failed' until an
# operator intervenes. Default 20 = 5 in-flight (§3.7.1) + 15 long-tail
# (§3.7.7).
ORACLE_MAX_TOTAL_RETRIES=20

# How often the long-tail retry sweep runs. Default 1h. The per-row
# backoff schedule (1h / 4h / 24h) is independently enforced per
# §3.7.7 — this is just the wake-up cadence.
ORACLE_LONG_TAIL_INTERVAL_MS=3600000

# ─── Service identity ──────────────────────────────────────────────────────
# Reported by /health for cross-channel verification per §05.2.4. Must
# match the pubkey published in docs/oracle-authority.md and the live
# wallet in ORACLE_SOLANA_PRIVATE_KEY. Set explicitly so a misconfigured
# private key is caught at startup (the parsed pubkey is compared to
# this value; mismatch → refuse to start).
PEPTIDE_ORACLE_AUTHORITY_PUBKEY=

NODE_ENV=production
