# Copy to .env and fill in. .env is gitignored.
#
# All variables marked REQUIRED must be present at startup; the service
# refuses to come up otherwise (apps/oracle/src/config.ts validates).
#
# See docs/specs/01-onchain-commit-layer/03-service-architecture.md
# (§3.5 keypair, §3.6 RPC, §3.9 health) for the rationale behind each.

# ─── REQUIRED ───────────────────────────────────────────────────────────────

# Solana hot wallet that signs every commit. Base58-encoded 64-byte secret
# key. The matching pubkey must be published per §05.2.4 (GitHub +
# socials + docs site cross-reference).
#
# DO NOT commit. Mark as a Railway secret. See docs/operator-setup.md §3
# for generation procedure.
ORACLE_SOLANA_PRIVATE_KEY=

# Helius mainnet RPC URL with API key embedded.
# Format: https://mainnet.helius-rpc.com/?api-key=<KEY>
ORACLE_RPC_URL=

# Supabase project this service writes commit_cycles / twap_commits /
# commit_observations into. Same project as the rest of the stack.
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# ─── OPTIONAL (with sensible defaults) ──────────────────────────────────────

# Health endpoint port. Railway assigns the public port; this is the
# internal listen port that Railway's healthcheck hits.
HEALTH_PORT=8080

# Fallback RPC URL for §3.6.2 manual failover. Leave blank for v1
# (single-RPC operation).
ORACLE_RPC_URL_FALLBACK=

# ─── Balance thresholds (per §07.2.2 v1=26-peptide tuning) ──────────────────
# At median priority fees, ~0.23 SOL covers a 30-day buffer. At the high
# cap (~0.69 SOL/30d) the defaults below give ~13 days warn / ~7 days
# critical of headroom.
ORACLE_BALANCE_WARN_SOL=0.30
ORACLE_BALANCE_CRITICAL_SOL=0.15

# Refuse to start if balance is below this at boot. Catches misconfigured
# deploys before they generate a wave of insufficient-SOL failures.
ORACLE_MIN_STARTUP_BALANCE_SOL=0.05

# How often to refresh the cached balance for /health. Default 5 min.
ORACLE_BALANCE_CHECK_INTERVAL_MS=300000

# ─── Polling cadences (per §03.2.1, §03.3.1) ────────────────────────────────
# Cycle poller cadence: how often we check scraper_runs for new completed
# cycles needing a commit. Default 30s.
ORACLE_CYCLE_POLL_INTERVAL_MS=30000

# TWAP poller cadence: how often the TWAP-loop wakes to check the
# top-of-hour boundary. Default 60s.
ORACLE_TWAP_POLL_INTERVAL_MS=60000

# ─── Confirmation polling (per §03.4.6) ─────────────────────────────────────
# Total time to wait for a submitted tx to reach finalized commitment.
# Default 90s — covers worst-case finalization under congestion.
ORACLE_CONFIRMATION_TIMEOUT_MS=90000

# How often to poll getSignatureStatuses while waiting for finality.
ORACLE_CONFIRMATION_POLL_INTERVAL_MS=3000

# ─── Health staleness rule (per §03.9.2) ────────────────────────────────────
# If cycle.last_commit_at is older than this, /health flips to 503.
ORACLE_HEALTH_STALE_THRESHOLD_MS=1800000

# Warm-up window after startup during which staleness checks are skipped
# (so a fresh deploy isn't immediately reported unhealthy).
ORACLE_HEALTH_WARMUP_MS=3600000

# ─── Service identity ──────────────────────────────────────────────────────
# Reported by /health for cross-channel verification per §05.2.4. Must
# match the pubkey published in docs/oracle-authority.md and the live
# wallet in ORACLE_SOLANA_PRIVATE_KEY. Set explicitly so a misconfigured
# private key is caught at startup (the parsed pubkey is compared to
# this value; mismatch → refuse to start).
PEPTIDE_ORACLE_AUTHORITY_PUBKEY=

NODE_ENV=production
