# Copy to .env and fill in. .env is gitignored.

# Supabase: shared with scraper/worker.
SUPABASE_URL=https://pjsjaspntdjecfitogtc.supabase.co

# Service-role key — bypasses RLS for trusted DB writes (positions,
# point_balances mutations, etc.). Never ship to the browser.
SUPABASE_SECRET_KEY=

# JWT secret used by Supabase Auth to sign user access tokens (HS256).
# We verify incoming Bearer tokens locally with this secret — no network
# round-trip per request. Find it in Supabase dashboard → Project Settings
# → API → "JWT Secret" (legacy section). Distinct from SUPABASE_SECRET_KEY.
SUPABASE_JWT_SECRET=

# HTTP ports.
#  - API_PORT     serves user-facing routes (/balance, /positions, …)
#  - HEALTH_PORT  serves only /health for Railway's deploy check
API_PORT=3000
HEALTH_PORT=8080

# Comma-separated extra origins to allow via CORS, in addition to the
# baked-in localhost + *.lovable.{app,dev,project.com} patterns.
CORS_ORIGINS=

# Optional: written to scraper_runs.git_sha-style audit fields when added later.
GIT_SHA=
