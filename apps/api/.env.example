# Copy to .env and fill in. .env is gitignored.

# Supabase: shared with scraper/worker/oracle. The canonical
# peptide-oracle project is mnquozxfniasbpaavcos. The earlier
# biohack.market project (pjsjaspntdjecfitogtc) is preserved
# read-only for legacy data — do not point new deploys at it.
SUPABASE_URL=https://mnquozxfniasbpaavcos.supabase.co

# Service-role key — bypasses RLS for trusted DB reads (verification
# endpoints traverse supplier_observations + commit_cycles). Never
# ship to the browser. Same value as the scraper / oracle services.
SUPABASE_SECRET_KEY=

# Note: no JWT secret needed. Supabase signs user access tokens with an
# asymmetric ES256 key; we fetch the matching public key set lazily from
# <SUPABASE_URL>/auth/v1/.well-known/jwks.json (cached 10 min by jose's
# createRemoteJWKSet helper).

# Solana RPC URL for the verification endpoint's on-chain Memo lookup.
# The cluster is implied by the URL — devnet vs mainnet is a deploy-
# time choice, not a runtime flag. Read-only operations only; the API
# never signs txs.
#
#   mainnet:  https://mainnet.helius-rpc.com/?api-key=<KEY>
#   devnet:   https://devnet.helius-rpc.com/?api-key=<KEY>
ORACLE_RPC_URL=

# Oracle's signing pubkey, base58. Returned by GET /authority and
# checked by the /v1/verify/observation endpoint against the on-chain
# tx's signers. MUST match the keypair the running oracle service
# signs with — if the API and oracle disagree on this value, every
# verification will fail signer_matches_authority.
PEPTIDE_ORACLE_AUTHORITY_PUBKEY=

# HTTP port. /health and user-facing routes share the same port so
# Railway's single-port healthcheck routes correctly. Railway also
# auto-injects PORT, which takes precedence over API_PORT.
API_PORT=3000

# Comma-separated extra origins to allow via CORS, in addition to the
# baked-in localhost + *.lovable.{app,dev,project.com} patterns.
CORS_ORIGINS=

# Optional: written to scraper_runs.git_sha-style audit fields when added later.
GIT_SHA=
