# Copy to .env and fill in. .env is gitignored.

# Supabase: shared with scraper/worker.
SUPABASE_URL=https://pjsjaspntdjecfitogtc.supabase.co

# Service-role key — bypasses RLS for trusted DB writes (positions,
# point_balances mutations, etc.). Never ship to the browser.
SUPABASE_SECRET_KEY=

# Note: no JWT secret needed. Supabase signs user access tokens with an
# asymmetric ES256 key; we fetch the matching public key set lazily from
# <SUPABASE_URL>/auth/v1/.well-known/jwks.json (cached 10 min by jose's
# createRemoteJWKSet helper).

# HTTP port. /health and user-facing routes share the same port so
# Railway's single-port healthcheck routes correctly. Railway also
# auto-injects PORT, which takes precedence over API_PORT.
API_PORT=3000

# Comma-separated extra origins to allow via CORS, in addition to the
# baked-in localhost + *.lovable.{app,dev,project.com} patterns.
CORS_ORIGINS=

# Optional: written to scraper_runs.git_sha-style audit fields when added later.
GIT_SHA=
