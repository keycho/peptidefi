# Copy to .env and fill in. .env is gitignored.

# Supabase: shared with scraper / oracle / api.
#
# As of the BioHash rebrand the canonical project is
# mnquozxfniasbpaavcos.supabase.co. The earlier biohack.market
# project (pjsjaspntdjecfitogtc) is preserved read-only for legacy
# data — do not point the worker at it (writes would land in the
# wrong project + the oracle's twap-poller wouldn't see them).
SUPABASE_URL=https://mnquozxfniasbpaavcos.supabase.co
SUPABASE_SECRET_KEY=

# Optional: identifies the running container if we ever extend run logging.
HOST_OVERRIDE=

# ─── Cycle cadence ──────────────────────────────────────────────────────────
# Loop interval in milliseconds. Default 60000 (1 minute) — the worker
# writes one peptide_twaps row per active peptide per minute.
WORKER_CYCLE_INTERVAL_MS=60000

# ─── Freshness ceiling ──────────────────────────────────────────────────────
# Observations older than this are dropped from a cycle's input set —
# beyond the ceiling the data is too stale to publish; the worker writes
# a thin-data row (twap_usd_per_mg=NULL) rather than show last-week's
# prices. Default 1800000 ms (30 minutes), comfortably wider than the
# scraper's 10-minute cadence.
#
# WORKER_TWAP_WINDOW_MS is read as a fallback name for back-compat with
# pre-rename .env files. New deploys should use WORKER_FRESHNESS_CEILING_MS.
WORKER_FRESHNESS_CEILING_MS=1800000

# ─── Cross-service sanity check (optional) ─────────────────────────────────
# Set to the same value as the scraper service's SCRAPER_CYCLE_INTERVAL_MS
# so the worker can warn at startup if its window is narrower than the
# scrape cadence (which would produce a wave of thin-data rows between
# scrapes). Leave unset to skip the check.
# SCRAPER_CYCLE_INTERVAL_MS=600000
