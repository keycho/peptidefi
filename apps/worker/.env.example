# Copy to .env and fill in. .env is gitignored.

SUPABASE_URL=https://pjsjaspntdjecfitogtc.supabase.co
SUPABASE_SECRET_KEY=

# Optional: identifies the running container if we ever extend run logging.
HOST_OVERRIDE=

# ─── Cycle cadence ──────────────────────────────────────────────────────────
# Loop interval in milliseconds. Default 60000 (1 minute).
WORKER_CYCLE_INTERVAL_MS=60000

# ─── TWAP window ────────────────────────────────────────────────────────────
# Lookback window in milliseconds. Default 300000 (5 minutes). Only the most
# recent successful supplier_observation per supplier within the window
# contributes to that cycle's TWAP.
WORKER_TWAP_WINDOW_MS=300000
