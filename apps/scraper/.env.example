# Copy to .env and fill in. .env is gitignored.

# Backend services use the SECRET key (RLS bypass). Never ship to the browser.
SUPABASE_URL=https://pjsjaspntdjecfitogtc.supabase.co
SUPABASE_SECRET_KEY=

# Optional: identifies the running container in scraper_runs.host. Falls
# back to os.hostname() when unset.
HOST_OVERRIDE=

# Optional: written to scraper_runs.git_sha for incident triage. Set by
# Railway from $RAILWAY_GIT_COMMIT_SHA, by GitHub Actions from $GITHUB_SHA,
# or manually for local debugging.
GIT_SHA=

# ─── Cycle cadence ──────────────────────────────────────────────────────────
# Loop interval in milliseconds. Default 60000. The legacy SCRAPE_INTERVAL_MS
# is still read as a fallback so existing .env files keep working.
#   60000  = 1 min  (production cadence)
#   600000 = 10 min (recommended during ScrapingAnt free-tier soak; 6 credits
#                    per cycle × 6 cycles/hour = 36 credits/hour, ~7 days
#                    on the 10,000-credit free tier)
SCRAPER_CYCLE_INTERVAL_MS=60000

# ─── ScrapingAnt proxy (optional) ───────────────────────────────────────────
# When SCRAPER_USE_PROXY=true and SCRAPINGANT_API_KEY is set, every
# WooCommerce catalog fetch is routed through ScrapingAnt's /v2/general
# endpoint with browser=false (1 credit each, no JS rendering — perfect for
# JSON Store API endpoints). This unblocks vendors that flag datacenter IPs
# (Sucuri / Cloudflare).
#
# When SCRAPER_USE_PROXY=false (default), every fetch is direct from the
# scraper host's IP — fine on residential/office IPs, gets rate-limited
# on most cloud / sandbox IPs.
#
# The pricing helper computes credits as: 6 vendors × 1 credit per cycle.
# At a 10-min cycle that's ~864 credits/day, ~25k/month — fits the cheapest
# paid tier.
SCRAPER_USE_PROXY=false
SCRAPINGANT_API_KEY=
