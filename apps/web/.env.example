# Copy to .env.local and fill in. .env.local is gitignored.
# Values: Supabase dashboard → Project Settings → API.
#
# These names match the new Supabase API key format
# (sb_publishable_... / sb_secret_...). The publishable key is safe to ship to
# the client; the secret key bypasses RLS and must never appear in client code.

NEXT_PUBLIC_SUPABASE_URL=https://pjsjaspntdjecfitogtc.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
